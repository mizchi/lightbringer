amends "https://raw.githubusercontent.com/mizchi/pkfire/main/pkl/Taskfile.pkl"

local sources: Listing<String> = new {
  "src/**/*.ts"
  "scripts/**/*.mjs"
  "examples/**/*.ts"
}

local typecheck: Task = new {
  name = "typecheck"
  // pnpm exec resolves the local binary; the git pre-push hook runs without
  // direnv, so node_modules/.bin is not on PATH and bare `tsc` is not found.
  cmd = "pnpm exec tsc --noEmit"
  inputs {
    ...sources
    "tsconfig.json"
  }
}

local testUnit: Task = new {
  name = "test:unit"
  cmd = "pnpm exec vitest run"
  inputs = sources
}

local lint: Task = new {
  name = "lint"
  cmd = "pnpm exec oxlint"
  inputs = sources
}

// secretlint scans the working tree for leaked credentials. Wired to pre-push
// (not pre-commit) so it runs at the boundary with the outside world.
local secretlint: Task = new {
  name = "secretlint"
  cmd = "npx secretlint --secretlintignore .gitignore \"**/*\""
  cache = false
}

local prePush: Task = new {
  name = "pre-push"
  cache = false
  // git's pre-push hook passes <remote> <url> positionally; accept and ignore them.
  acceptsArgs = true
  deps {
    secretlint
    typecheck
  }
}

tasks {
  typecheck
  testUnit
  lint
  secretlint
  prePush
}
