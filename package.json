{
  "name": "lightbringer",
  "version": "0.1.0",
  "description": "Per-step resource measurement for Playwright scenarios: network / CPU / render / INP at initialization and between steps, to optimize a scenario's resource usage. Median regression gate and trace drilldown.",
  "type": "module",
  "license": "MIT",
  "author": "mizchi",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizchi/lightbringer"
  },
  "keywords": [
    "playwright",
    "performance",
    "web-vitals",
    "cdp",
    "tracing"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "bin": {
    "lightbringer-median": "scripts/median.mjs",
    "lightbringer-drilldown": "scripts/drilldown.mjs"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "tsup src/index.ts --format esm --dts --clean",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:bundle": "playwright test -c playwright.bundle.config.ts",
    "bundle:gen": "node fixtures/bundle/gen-image.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "fix": "oxlint --fix",
    "median": "node scripts/median.mjs",
    "drilldown": "node scripts/drilldown.mjs",
    "regress": "node scripts/regress.mjs",
    "coverage": "node scripts/coverage.mjs"
  },
  "dependencies": {
    "web-vitals": "^5.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.50.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "secretlint": "^9.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.16.0"
}
